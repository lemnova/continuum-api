# ======================================================================
# CONTINUUM BACKEND - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in your actual credentials.
# ======================================================================

# ---- Server & General ----
SERVER_PORT=8080
APP_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Database (MongoDB) ----
# Example: mongodb://localhost:27017/continuum or mongodb+srv://...
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/continuum

# ---- Security & JWT ----
# Generate a secure 256-bit key (e.g., openssl rand -base64 32)
JWT_SECRET=your_super_secret_key_at_least_32_characters_long
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000
JWT_EXPIRATION=900000

# ---- Email (Resend) ----
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_VERIFICATION_URL=http://localhost:5173/verify-email

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PLUS=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_VISION=price_...
STRIPE_SUCCESS_URL=http://localhost:5173/subscription/success
STRIPE_CANCEL_URL=http://localhost:5173/subscription/cancel

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ---- Storage (Backblaze B2 / S3 Compatible) ----
VAULT_B2_ENDPOINT=s3.us-east-005.backblazeb2.com
VAULT_B2_BUCKET=your-bucket-name
VAULT_B2_ACCESS_KEY=your_access_key
VAULT_B2_SECRET_KEY=your_secret_key
VAULT_B2_REGION=us-east-005

# ---- Plan Limits (Optional Overrides) ----
PLAN_FREE_MAX_ENTITIES=20
PLAN_FREE_MAX_NOTES=50
PLAN_FREE_MAX_VAULT_SIZE_MB=100

PLAN_PLUS_MAX_ENTITIES=100
PLAN_PLUS_MAX_NOTES=500
PLAN_PLUS_MAX_VAULT_SIZE_MB=1024

PLAN_PRO_MAX_ENTITIES=-1
PLAN_PRO_MAX_NOTES=-1
PLAN_PRO_MAX_VAULT_SIZE_MB=2048

PLAN_GOLD_MAX_ENTITIES=-1
PLAN_GOLD_MAX_NOTES=-1
PLAN_GOLD_MAX_VAULT_SIZE_MB=4096

# ---- System Internal ----
JOURNAL_MAX_CONTENT_SIZE=1048576
VAULT_METADATA_CACHE_TTL=300